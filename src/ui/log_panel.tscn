[node name="HSeparator" type="VSeparator" parent="VBoxContainer/ToolBar"]
layout_mode = 2

[node name="AutoScrollCheck" type="CheckBox" parent="VBoxContainer/ToolBar"]
layout_mode = 2
button_pressed = true
text = "自动滚动"

[node name="HSpacer" type="Control" parent="VBoxContainer/ToolBar"]
layout_mode = 2
