[node name="LogPanel" type="PanelContainer"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
size_flags_vertical = 3
script = ExtResource("1_logpanel")

[node name="VBoxContainer" type="VBoxContainer" parent="."]
layout_mode = 2

[node name="ToolBar" type="HBoxContainer" parent="VBoxContainer"]
layout_mode = 2

[node name="TitleLabel" type="Label" parent="VBoxContainer/ToolBar"]
layout_mode = 2
